# Save this as .gitignore
cat > .gitignore << 'EOF'
# dependencies
node_modules/
**/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/
/build
.next/
out/

# production
/build

# misc
.DS_Store
*.pem
*.jar
*.py
*.txt
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Media files - stored in R2
/public/audio/**
/public/uploads/**
/public/videos/**
/public/pdfs/**
*.mp3
*.mp4
*.wav
*.pdf

# Wrangler (Cloudflare)
.wrangler/
wrangler.toml
.wrangler-*

# Local data
*.local

# Temporary files
temp/
tmp/
*.tmp

# Backend (separate API)
/backend/
/api-*/

# Local images - now using R2
public/eastc.jpeg
public/eastc1.jpeg
public/eastc2.jpeg
public/image/
public/logo.png
EOF